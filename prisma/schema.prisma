// GoalEdge — Smarter Football Predictions
// Prisma schema (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          String         @default("user")
  plan          String         @default("free")
  avatarColor   String         @default("#10b981")
  planExpiresAt DateTime?
  referralCode  String?        @unique
  referredBy    String?
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  betSlips      BetSlip[]
  activities    ActivityLog[]
  follows       Follow[]
  passwordResets PasswordReset[]
}

model Prediction {
  id         Int      @id @default(autoincrement())
  homeTeam   String
  awayTeam   String
  league     String
  leagueIcon String   @default("⚽")
  country    String   @default("International")
  kickoffAt  DateTime
  tip        String
  market     String   @default("Match Result")
  odds       Float
  confidence Int      @default(75)
  risk       String   @default("medium")
  analysis   String?
  isPremium  Boolean  @default(false)
  status     String   @default("upcoming")
  scoreHome  Int?
  scoreAway  Int?
  tipster    String   @default("Arena Tipster")
  createdAt  DateTime @default(now())
}

model Subscription {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reference String    @unique
  email     String?
  amount    Int
  currency  String    @default("KES")
  plan      String
  status    String    @default("initialized")
  provider  String    @default("paystack")
  createdAt DateTime  @default(now())
  paidAt    DateTime?
}

model BetSlip {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  predictionIds String   @default("[]")
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  detail    String?
  createdAt DateTime @default(now())
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followeeId  String
  follower    User     @relation(fields: [followerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followeeId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}
